# PostgreSQL
# Для Docker используйте имя сервиса: postgres. Для локальной разработки: localhost
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=auth

# JWT (RS256): ключи берутся из keys/ или из переменных JWT_KEY_<KID>_PRIVATE_B64 / JWT_KEY_<KID>_PUBLIC_B64
# JWT_SECRET_KEY не используется при RS256
JWT_ALGORITHM=RS256
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=3

# Админ по умолчанию
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin

# Хранение ключей: filesystem — каталог keys/; environment — переменные JWT_KEY_<KID>_*
JWT_KEYS_DIR=keys
JWT_STORAGE_BACKEND=filesystem
JWT_ENV_PREFIX=JWT_KEY
ENV_FILE_PATH=.env

ALLOWED_ORIGINS=["https://gol1.my.project","https://gol2.my.project","http://localhost:3000"]
#COOKIE_DOMAIN=.my.project
COOKIE_DOMAIN=
COOKIE_SECURE=False          # Включить для HTTPS
COOKIE_SAMESITE=lax          # lax, strict или none
