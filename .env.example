# Для Docker используйте имя сервиса: postgres. Для локальной разработки: localhost
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=auth
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin
ALLOWED_ORIGINS=["https://gol1.my.project","https://gol2.my.project","http://localhost:3000"]
#COOKIE_DOMAIN=.my.project
COOKIE_DOMAIN=
# JWT settings
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

COOKIE_SECURE=False          # Включить для HTTPS
COOKIE_SAMESITE=lax          # lax, strict или none


